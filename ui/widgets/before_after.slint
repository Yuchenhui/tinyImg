import { Palette } from "../theme/palette.slint";
import { Typography } from "../theme/typography.slint";

// 压缩前后对比滑块组件
export component BeforeAfter inherits Rectangle {
    in property <image> before-image;
    in property <image> after-image;
    in-out property <float> split-position: 0.5;  // 0.0 ~ 1.0

    border-radius: Palette.radius-md;
    background: Palette.bg-tertiary;
    clip: true;

    // 底层：after 图（压缩后，右侧完整显示）
    Image {
        source: after-image;
        image-fit: contain;
        width: 100%;
        height: 100%;
    }

    // 上层：before 图（原图，通过 clip 容器只显示左侧部分）
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width * split-position;
        height: 100%;
        clip: true;

        Image {
            source: before-image;
            image-fit: contain;
            width: root.width;
            height: root.height;
        }
    }

    // 分割线
    Rectangle {
        x: parent.width * split-position - 1.5px;
        y: 0;
        width: 3px;
        height: 100%;
        background: #ffffff;

        // 圆形拖拽手柄
        Rectangle {
            x: -14.5px;
            y: (parent.height - 32px) / 2;
            width: 32px;
            height: 32px;
            border-radius: 16px;
            background: #ffffff;
            border-width: 2px;
            border-color: Palette.primary;

            // 左右箭头指示
            Text {
                text: "◀▶";
                font-size: 10px;
                color: Palette.primary;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    // "原图" 角标
    Rectangle {
        x: Palette.spacing-sm;
        y: Palette.spacing-sm;
        width: label-before.preferred-width + 12px;
        height: label-before.preferred-height + 6px;
        border-radius: Palette.radius-sm;
        background: #000000.with-alpha(0.6);

        label-before := Text {
            text: @tr("原图");
            font-size: Typography.font-size-xs;
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // "压缩后" 角标
    Rectangle {
        x: parent.width - label-after.preferred-width - 12px - Palette.spacing-sm;
        y: Palette.spacing-sm;
        width: label-after.preferred-width + 12px;
        height: label-after.preferred-height + 6px;
        border-radius: Palette.radius-sm;
        background: #000000.with-alpha(0.6);

        label-after := Text {
            text: @tr("压缩后");
            font-size: Typography.font-size-xs;
            color: #ffffff;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // 拖拽区域（覆盖整个组件）
    TouchArea {
        moved => {
            split-position = clamp(self.mouse-x / root.width, 0.05, 0.95);
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                split-position = clamp(self.mouse-x / root.width, 0.05, 0.95);
            }
        }
    }
}
