import { Palette } from "theme/palette.slint";
import { Typography } from "theme/typography.slint";
import { AppBridge } from "globals/bridge.slint";
import { AppState } from "globals/state.slint";
import { CompressPage } from "pages/compress.slint";
import { SettingsPage } from "pages/settings.slint";
import { AboutPage } from "pages/about.slint";

export { AppBridge, AppState }

export component AppWindow inherits Window {
    title: "TinyImg";
    min-width: 800px;
    min-height: 600px;
    preferred-width: 960px;
    preferred-height: 680px;
    background: Palette.bg-primary;

    in-out property <int> current-page: 0;  // 0=compress, 1=settings, 2=about

    HorizontalLayout {
        // 侧边导航栏
        Rectangle {
            width: 48px;
            background: Palette.bg-secondary;
            border-width: 0px;

            VerticalLayout {
                alignment: start;
                padding-top: Palette.spacing-md;
                spacing: Palette.spacing-xs;

                // 压缩页
                Rectangle {
                    height: 40px;
                    width: 40px;
                    x: 4px;
                    border-radius: Palette.radius-sm;
                    background: current-page == 0 ? Palette.primary.with-alpha(0.1) : transparent;

                    TouchArea {
                        clicked => { current-page = 0; }
                    }

                    Text {
                        text: "🖼";
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // 设置页
                Rectangle {
                    height: 40px;
                    width: 40px;
                    x: 4px;
                    border-radius: Palette.radius-sm;
                    background: current-page == 1 ? Palette.primary.with-alpha(0.1) : transparent;

                    TouchArea {
                        clicked => { current-page = 1; }
                    }

                    Text {
                        text: "⚙";
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // 关于页
                Rectangle {
                    height: 40px;
                    width: 40px;
                    x: 4px;
                    border-radius: Palette.radius-sm;
                    background: current-page == 2 ? Palette.primary.with-alpha(0.1) : transparent;

                    TouchArea {
                        clicked => { current-page = 2; }
                    }

                    Text {
                        text: "ℹ";
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // 主内容区
        Rectangle {
            horizontal-stretch: 1;

            if current-page == 0 : CompressPage {}
            if current-page == 1 : SettingsPage {}
            if current-page == 2 : AboutPage {}
        }
    }
}
