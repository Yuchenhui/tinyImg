// 颜色系统定义
export global Palette {
    // 主色调
    out property <color> primary: #2563eb;
    out property <color> primary-hover: #1d4ed8;
    out property <color> primary-active: #1e40af;

    // 背景
    out property <color> bg-primary: #ffffff;
    out property <color> bg-secondary: #f8fafc;
    out property <color> bg-tertiary: #f1f5f9;

    // 文字
    out property <color> text-primary: #0f172a;
    out property <color> text-secondary: #475569;
    out property <color> text-muted: #94a3b8;

    // 边框
    out property <color> border: #e2e8f0;
    out property <color> border-hover: #cbd5e1;

    // 状态色
    out property <color> success: #16a34a;
    out property <color> warning: #d97706;
    out property <color> error: #dc2626;

    // 阴影/遮罩
    out property <color> overlay: #0f172a.with-alpha(0.5);

    // 圆角
    out property <length> radius-sm: 4px;
    out property <length> radius-md: 8px;
    out property <length> radius-lg: 12px;

    // 间距
    out property <length> spacing-xs: 4px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 16px;
    out property <length> spacing-lg: 24px;
    out property <length> spacing-xl: 32px;
}
