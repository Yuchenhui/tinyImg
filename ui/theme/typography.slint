// 字体规格定义
export global Typography {
    out property <length> font-size-xs: 11px;
    out property <length> font-size-sm: 13px;
    out property <length> font-size-base: 14px;
    out property <length> font-size-lg: 16px;
    out property <length> font-size-xl: 20px;
    out property <length> font-size-2xl: 24px;
    out property <length> font-size-3xl: 30px;

    out property <int> font-weight-normal: 400;
    out property <int> font-weight-medium: 500;
    out property <int> font-weight-semibold: 600;
    out property <int> font-weight-bold: 700;
}
