// Rust → UI 状态数据
// Rust 侧通过 set_xxx() / model.push() 更新状态

// 图片列表项数据
export struct ImageItem {
    id: int,
    filename: string,
    filepath: string,
    format: string,
    original-size: string,
    compressed-size: string,
    compression-ratio: string,
    status: string,        // "pending" | "processing" | "completed" | "failed"
    error-message: string,
    output-path: string,   // 压缩后文件路径
}

// 预设数据
export struct PresetItem {
    name: string,
    description: string,
    builtin: bool,
}

export global AppState {
    // ===== 图片列表 =====
    in-out property <[ImageItem]> images: [];

    // ===== 全局进度 =====
    in-out property <float> progress: 0.0;
    in-out property <int> total-count: 0;
    in-out property <int> completed-count: 0;
    in-out property <string> status-text: "就绪";

    // ===== 压缩等级（1-10 滑块） =====
    // 压缩模式：0=压缩强度, 1=文件大小
    in-out property <int> compression-mode: 0;
    // 1-10 压缩等级
    in-out property <int> compression-level: 3;

    // ===== 高级设置展开 =====
    in-out property <bool> show-advanced: false;

    // ===== 尺寸设置 =====
    in-out property <bool> maintain-aspect-ratio: true;

    // ===== 保存路径模式 =====
    // 0=原文件夹, 1=覆盖原文件, 2=自定义文件夹
    in-out property <int> save-path-mode: 0;

    // ===== 预设（后端保留，UI 不再展示） =====
    in-out property <string> current-preset: "web_optimized";
    in-out property <[PresetItem]> presets: [];
    in-out property <[string]> preset-names: [];
    in-out property <int> current-preset-index: 0;

    // ===== 压缩参数（按格式） =====
    // JPEG
    in-out property <int> jpeg-quality: 80;
    in-out property <bool> jpeg-progressive: true;
    // PNG
    in-out property <bool> png-lossy: false;
    in-out property <int> png-optimization: 2;
    // WebP
    in-out property <int> webp-quality: 80;
    in-out property <bool> webp-lossless: true;
    // AVIF
    in-out property <int> avif-quality: 70;
    in-out property <int> avif-speed: 4;
    // GIF
    in-out property <int> gif-quality: 80;
    in-out property <bool> gif-fast: false;

    // ===== 输出设置 =====
    // 输出格式: 0=保持原格式, 1=JPEG, 2=PNG, 3=WebP, 4=AVIF, 5=GIF
    in-out property <int> output-format-index: 0;
    in-out property <[string]> output-format-names: ["保持原格式", "JPEG", "PNG", "WebP", "AVIF", "GIF"];
    in-out property <string> output-suffix: "_compressed";
    in-out property <bool> output-same-dir: true;
    in-out property <string> output-custom-dir: "";
    in-out property <bool> overwrite: false;

    // ===== 处理设置 =====
    in-out property <bool> strip-metadata: true;
    in-out property <bool> resize-enabled: false;
    in-out property <int> max-width: 0;
    in-out property <int> max-height: 0;

    // ===== 预览 =====
    in-out property <bool> preview-visible: false;
    in-out property <int> preview-id: -1;
    in-out property <image> preview-before-image;
    in-out property <image> preview-after-image;
    in-out property <string> preview-filename: "";
    in-out property <string> preview-original-size: "";
    in-out property <string> preview-compressed-size: "";
    in-out property <string> preview-compression-ratio: "";
    in-out property <string> preview-dimensions: "";
    in-out property <bool> preview-loading: false;

    // ===== 系统 =====
    in-out property <string> language: "zh-CN";
    in-out property <string> theme: "system";
    in-out property <bool> gpu-available: false;
    in-out property <string> gpu-name: "";
}
