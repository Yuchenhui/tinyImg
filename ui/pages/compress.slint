import { Palette } from "../theme/palette.slint";
import { Typography } from "../theme/typography.slint";
import { AppBridge } from "../globals/bridge.slint";
import { AppState, ImageItem } from "../globals/state.slint";
import { DropZone } from "../widgets/drop_zone.slint";
import { ImageCard } from "../widgets/image_card.slint";
import { ProgressBar } from "../widgets/progress_bar.slint";
import { BeforeAfter } from "../widgets/before_after.slint";
import { ComboBox } from "std-widgets.slint";

// 主压缩页面
export component CompressPage inherits HorizontalLayout {
    spacing: 0px;

    // ===== 左侧：主列表区 =====
    VerticalLayout {
        horizontal-stretch: 1;
        spacing: Palette.spacing-md;
        padding: Palette.spacing-lg;

        // 拖拽区域（图片列表为空时显示大区域）
        if AppState.images.length == 0 : DropZone {
            clicked => { AppBridge.add-files(); }
        }

        // 图片列表（有图片时显示）
        if AppState.images.length > 0 : VerticalLayout {
            spacing: Palette.spacing-sm;

            // 工具栏
            HorizontalLayout {
                spacing: Palette.spacing-sm;
                alignment: stretch;

                Text {
                    text: @tr("{} 张图片", AppState.images.length);
                    font-size: Typography.font-size-base;
                    color: Palette.text-primary;
                    vertical-alignment: center;
                }

                // 预设选择器
                ComboBox {
                    model: AppState.preset-names;
                    current-index <=> AppState.current-preset-index;
                    selected(value) => { AppBridge.select-preset(value); }
                    min-width: 140px;
                    horizontal-stretch: 0;
                }

                Rectangle { horizontal-stretch: 1; }

                // 添加更多
                Rectangle {
                    border-radius: Palette.radius-sm;
                    background: Palette.bg-secondary;
                    horizontal-stretch: 0;

                    TouchArea {
                        clicked => { AppBridge.add-files(); }
                    }

                    HorizontalLayout {
                        padding: Palette.spacing-sm;
                        Text {
                            text: @tr("+ 添加");
                            font-size: Typography.font-size-sm;
                            color: Palette.primary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // 清空
                Rectangle {
                    border-radius: Palette.radius-sm;
                    background: Palette.bg-secondary;
                    horizontal-stretch: 0;

                    TouchArea {
                        clicked => { AppBridge.clear-all(); }
                    }

                    HorizontalLayout {
                        padding: Palette.spacing-sm;
                        Text {
                            text: @tr("清空");
                            font-size: Typography.font-size-sm;
                            color: Palette.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // 全局进度条
            ProgressBar {
                value: AppState.progress;
            }

            // 图片列表
            Flickable {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: Palette.spacing-xs;

                    for item[index] in AppState.images : ImageCard {
                        item: item;
                        selected: item.id == AppState.preview-id && AppState.preview-visible;
                        remove(id) => { AppBridge.remove-image(id); }
                        request-preview(id) => { AppBridge.request-preview(id); }
                    }
                }
            }

            // 底部操作栏
            HorizontalLayout {
                spacing: Palette.spacing-md;
                alignment: end;

                // 状态文本
                Text {
                    text: AppState.status-text;
                    font-size: Typography.font-size-sm;
                    color: Palette.text-muted;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // 开始压缩按钮
                Rectangle {
                    border-radius: Palette.radius-md;
                    background: Palette.primary;
                    horizontal-stretch: 0;

                    TouchArea {
                        clicked => { AppBridge.compress-all(); }
                    }

                    HorizontalLayout {
                        padding-left: Palette.spacing-lg;
                        padding-right: Palette.spacing-lg;
                        padding-top: Palette.spacing-sm;
                        padding-bottom: Palette.spacing-sm;

                        Text {
                            text: @tr("开始压缩");
                            font-size: Typography.font-size-base;
                            color: #ffffff;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ===== 右侧：预览面板 =====
    if AppState.preview-visible : Rectangle {
        width: 450px;
        background: Palette.bg-secondary;
        border-width: 1px;
        border-color: Palette.border;

        VerticalLayout {
            spacing: Palette.spacing-sm;
            padding: Palette.spacing-md;

            // 标题栏
            HorizontalLayout {
                spacing: Palette.spacing-sm;
                alignment: stretch;

                Text {
                    text: AppState.preview-filename;
                    font-size: Typography.font-size-lg;
                    color: Palette.text-primary;
                    overflow: elide;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // 关闭按钮
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Palette.radius-sm;
                    background: close-ta.has-hover ? Palette.bg-tertiary : transparent;
                    horizontal-stretch: 0;

                    close-ta := TouchArea {
                        clicked => { AppBridge.close-preview(); }
                    }

                    Text {
                        text: "✕";
                        font-size: Typography.font-size-base;
                        color: Palette.text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // 对比区域
            if AppState.preview-loading : Rectangle {
                vertical-stretch: 1;
                background: Palette.bg-tertiary;
                border-radius: Palette.radius-md;

                Text {
                    text: @tr("加载预览中...");
                    color: Palette.text-muted;
                    font-size: Typography.font-size-base;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if !AppState.preview-loading : BeforeAfter {
                vertical-stretch: 1;
                before-image: AppState.preview-before-image;
                after-image: AppState.preview-after-image;
            }

            // 文件信息
            Rectangle {
                background: Palette.bg-tertiary;
                border-radius: Palette.radius-md;
                height: info-layout.preferred-height + Palette.spacing-md * 2;

                info-layout := VerticalLayout {
                    padding: Palette.spacing-md;
                    spacing: Palette.spacing-xs;

                    // 尺寸
                    if AppState.preview-dimensions != "" : HorizontalLayout {
                        Text {
                            text: @tr("尺寸");
                            font-size: Typography.font-size-sm;
                            color: Palette.text-muted;
                            width: 70px;
                        }
                        Text {
                            text: AppState.preview-dimensions;
                            font-size: Typography.font-size-sm;
                            color: Palette.text-primary;
                        }
                    }

                    // 原始大小
                    HorizontalLayout {
                        Text {
                            text: @tr("原始大小");
                            font-size: Typography.font-size-sm;
                            color: Palette.text-muted;
                            width: 70px;
                        }
                        Text {
                            text: AppState.preview-original-size;
                            font-size: Typography.font-size-sm;
                            color: Palette.text-primary;
                        }
                    }

                    // 压缩后大小
                    HorizontalLayout {
                        Text {
                            text: @tr("压缩后");
                            font-size: Typography.font-size-sm;
                            color: Palette.text-muted;
                            width: 70px;
                        }
                        Text {
                            text: AppState.preview-compressed-size;
                            font-size: Typography.font-size-sm;
                            color: Palette.text-primary;
                        }
                    }

                    // 压缩率
                    HorizontalLayout {
                        Text {
                            text: @tr("压缩率");
                            font-size: Typography.font-size-sm;
                            color: Palette.text-muted;
                            width: 70px;
                        }
                        Text {
                            text: AppState.preview-compression-ratio;
                            font-size: Typography.font-size-sm;
                            color: Palette.success;
                        }
                    }
                }
            }
        }
    }
}
