import { Palette } from "../theme/palette.slint";
import { Typography } from "../theme/typography.slint";
import { AppState } from "../globals/state.slint";
import { AppBridge } from "../globals/bridge.slint";
import { Slider, CheckBox, ComboBox, SpinBox, LineEdit, GroupBox, ScrollView, Button } from "std-widgets.slint";

// 设置页面
export component SettingsPage inherits VerticalLayout {
    spacing: Palette.spacing-md;
    padding: Palette.spacing-lg;

    Text {
        text: @tr("设置");
        font-size: Typography.font-size-2xl;
        font-weight: Typography.font-weight-bold;
        color: Palette.text-primary;
    }

    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            spacing: Palette.spacing-lg;
            padding-right: Palette.spacing-md;

            // ========== 预设管理 ==========
            GroupBox {
                title: @tr("压缩预设");

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;

                        ComboBox {
                            model: AppState.preset-names;
                            current-index <=> AppState.current-preset-index;
                            selected(value) => { AppBridge.select-preset(value); }
                            horizontal-stretch: 1;
                        }
                    }
                }
            }

            // ========== JPEG 设置 ==========
            GroupBox {
                title: "JPEG";

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;
                        alignment: stretch;

                        Text {
                            text: @tr("质量");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        Slider {
                            minimum: 1;
                            maximum: 100;
                            value: AppState.jpeg-quality;
                            changed(value) => { AppState.jpeg-quality = round(value); }
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: AppState.jpeg-quality;
                            vertical-alignment: center;
                            min-width: 30px;
                            horizontal-alignment: right;
                            color: Palette.text-primary;
                        }
                    }

                    CheckBox {
                        text: @tr("渐进式编码（progressive）");
                        checked <=> AppState.jpeg-progressive;
                    }
                }
            }

            // ========== PNG 设置 ==========
            GroupBox {
                title: "PNG";

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    CheckBox {
                        text: @tr("有损压缩（imagequant 量化）");
                        checked <=> AppState.png-lossy;
                    }

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;
                        alignment: stretch;

                        Text {
                            text: @tr("优化等级");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        Slider {
                            minimum: 1;
                            maximum: 6;
                            value: AppState.png-optimization;
                            changed(value) => { AppState.png-optimization = round(value); }
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: AppState.png-optimization;
                            vertical-alignment: center;
                            min-width: 30px;
                            horizontal-alignment: right;
                            color: Palette.text-primary;
                        }
                    }
                }
            }

            // ========== WebP 设置 ==========
            GroupBox {
                title: "WebP";

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    CheckBox {
                        text: @tr("无损模式");
                        checked <=> AppState.webp-lossless;
                    }

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;
                        alignment: stretch;

                        Text {
                            text: @tr("质量");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        Slider {
                            minimum: 1;
                            maximum: 100;
                            value: AppState.webp-quality;
                            changed(value) => { AppState.webp-quality = round(value); }
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: AppState.webp-quality;
                            vertical-alignment: center;
                            min-width: 30px;
                            horizontal-alignment: right;
                            color: Palette.text-primary;
                        }
                    }
                }
            }

            // ========== AVIF 设置 ==========
            GroupBox {
                title: "AVIF";

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;
                        alignment: stretch;

                        Text {
                            text: @tr("质量");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        Slider {
                            minimum: 1;
                            maximum: 100;
                            value: AppState.avif-quality;
                            changed(value) => { AppState.avif-quality = round(value); }
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: AppState.avif-quality;
                            vertical-alignment: center;
                            min-width: 30px;
                            horizontal-alignment: right;
                            color: Palette.text-primary;
                        }
                    }

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;
                        alignment: stretch;

                        Text {
                            text: @tr("编码速度");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        Slider {
                            minimum: 1;
                            maximum: 10;
                            value: AppState.avif-speed;
                            changed(value) => { AppState.avif-speed = round(value); }
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: AppState.avif-speed;
                            vertical-alignment: center;
                            min-width: 30px;
                            horizontal-alignment: right;
                            color: Palette.text-primary;
                        }
                    }
                }
            }

            // ========== GIF 设置 ==========
            GroupBox {
                title: "GIF";

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;
                        alignment: stretch;

                        Text {
                            text: @tr("质量");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        Slider {
                            minimum: 1;
                            maximum: 100;
                            value: AppState.gif-quality;
                            changed(value) => { AppState.gif-quality = round(value); }
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: AppState.gif-quality;
                            vertical-alignment: center;
                            min-width: 30px;
                            horizontal-alignment: right;
                            color: Palette.text-primary;
                        }
                    }

                    CheckBox {
                        text: @tr("快速模式（质量稍低，速度更快）");
                        checked <=> AppState.gif-fast;
                    }
                }
            }

            // ========== 输出设置 ==========
            GroupBox {
                title: @tr("输出设置");

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;

                        Text {
                            text: @tr("输出格式");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        ComboBox {
                            model: AppState.output-format-names;
                            current-index <=> AppState.output-format-index;
                            horizontal-stretch: 1;
                        }
                    }

                    CheckBox {
                        text: @tr("输出到原文件目录");
                        checked <=> AppState.output-same-dir;
                    }

                    if !AppState.output-same-dir : HorizontalLayout {
                        spacing: Palette.spacing-sm;

                        Text {
                            text: AppState.output-custom-dir == "" ? @tr("未选择输出目录") : AppState.output-custom-dir;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            color: AppState.output-custom-dir == "" ? Palette.text-muted : Palette.text-primary;
                            overflow: elide;
                        }

                        Button {
                            text: @tr("浏览...");
                            clicked => { AppBridge.browse-output-dir(); }
                        }
                    }

                    HorizontalLayout {
                        spacing: Palette.spacing-sm;

                        Text {
                            text: @tr("文件后缀");
                            vertical-alignment: center;
                            min-width: 80px;
                            color: Palette.text-secondary;
                        }
                        LineEdit {
                            text <=> AppState.output-suffix;
                            horizontal-stretch: 1;
                            placeholder-text: "_compressed";
                        }
                    }

                    CheckBox {
                        text: @tr("覆盖原文件（不添加后缀）");
                        checked <=> AppState.overwrite;
                    }
                }
            }

            // ========== 处理设置 ==========
            GroupBox {
                title: @tr("处理设置");

                VerticalLayout {
                    spacing: Palette.spacing-sm;

                    CheckBox {
                        text: @tr("剥离元数据（EXIF / ICC / XMP）");
                        checked <=> AppState.strip-metadata;
                    }

                    CheckBox {
                        text: @tr("启用缩放");
                        checked <=> AppState.resize-enabled;
                    }

                    if AppState.resize-enabled : HorizontalLayout {
                        spacing: Palette.spacing-md;

                        HorizontalLayout {
                            spacing: Palette.spacing-sm;
                            Text {
                                text: @tr("最大宽度");
                                vertical-alignment: center;
                                color: Palette.text-secondary;
                            }
                            SpinBox {
                                minimum: 0;
                                maximum: 10000;
                                value <=> AppState.max-width;
                            }
                        }

                        HorizontalLayout {
                            spacing: Palette.spacing-sm;
                            Text {
                                text: @tr("最大高度");
                                vertical-alignment: center;
                                color: Palette.text-secondary;
                            }
                            SpinBox {
                                minimum: 0;
                                maximum: 10000;
                                value <=> AppState.max-height;
                            }
                        }
                    }
                }
            }

            // ========== GPU 状态 ==========
            GroupBox {
                title: @tr("GPU 加速");

                HorizontalLayout {
                    spacing: Palette.spacing-sm;

                    Text {
                        text: AppState.gpu-available
                            ? @tr("已启用: {}",  AppState.gpu-name)
                            : @tr("不可用（将使用 CPU 处理）");
                        color: AppState.gpu-available ? Palette.success : Palette.text-muted;
                        vertical-alignment: center;
                    }
                }
            }

            // 底部留白
            Rectangle { height: Palette.spacing-xl; }
        }
    }
}
